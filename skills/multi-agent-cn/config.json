{
  "dispatcher": {
    "name": "调度员",
    "role": "多 Agent 系统指挥官",
    "style": "直接、高效、不废话"
  },
  "subagents": {
    "alpha": {
      "name": "Alpha",
      "role": "首席技术官",
      "description": "15 年架构经验，复杂系统设计、性能优化、安全加固",
      "soul": "/root/.openclaw/workspace/agents/alpha-soul.md",
      "priority": 1
    },
    "bravo": {
      "name": "Bravo",
      "role": "首席分析师",
      "description": "前麦肯锡合伙人，代码审查、架构分析、风险识别",
      "priority": 2
    },
    "charlie": {
      "name": "Charlie",
      "role": "首席战略官",
      "description": "连续创业者，方案设计、战略规划、资源调配",
      "priority": 3
    },
    "delta": {
      "name": "Delta",
      "role": "首席工程师",
      "description": "工匠精神，bug 修复、文档编写、测试覆盖",
      "priority": 4
    },
    "echo": {
      "name": "Echo",
      "role": "首席情报官",
      "description": "前 NSA 分析师，情报收集、调研分析、快速学习",
      "soul": "/root/.openclaw/workspace/agents/echo-soul.md",
      "priority": 5
    }
  },
  "roundRobin": true,
  "parallelDispatch": true,
  "agentToAgent": {
    "allow": true,
    "max_concurrent": 10,
    "syntax": "@"
  },
  "selfReview": {
    "enabled": true,
    "script": "/root/.openclaw/workspace/agents/self-review.py",
    "autoUpdateAgentsMd": true
  },
  "permissionLevels": {
    "green": ["read", "search", "analyze"],
    "yellow": ["write", "modify", "deploy"],
    "red": ["delete", "production"]
  }
}
